# Run `node scripts/setup.mjs` to generate these values
TRADEWINDS_TOKEN=your_jwt_token_here
TRADEWINDS_COMPANY_ID=your_company_uuid_here

# Optional — defaults to https://tradewinds.fly.dev
# TRADEWINDS_API_URL=https://tradewinds.fly.dev

# Optional — MongoDB URI for persisting SSE events and autopilot state across restarts
# Without this the app works fully in-memory (events are lost on page reload / restart)
# MONGODB_URI=mongodb://localhost:27017/tradewinds
